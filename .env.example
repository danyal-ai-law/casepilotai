# Application
APP_NAME=CasePilot AI
APP_ENV=development
SECRET_KEY=your-secret-key-change-this
API_VERSION=v1

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://casepilot:casepilot_password@postgres:5432/casepilotai_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=casepilotai_db
DB_USER=casepilot
DB_PASSWORD=casepilot_password

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Admin
ADMIN_EMAIL=admin@casepilot.ai
ADMIN_PASSWORD=admin_password_change_this
